# PostgreSQL Neon (obligatoire)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# JWT — générer avec : openssl rand -base64 32 (obligatoire, min 32 chars)
JWT_SECRET=

# Serveur
PORT=3000
NODE_ENV=development

# CORS (en prod, mettre l'URL Render : https://votre-app.onrender.com)
CORS_ORIGIN=http://localhost:5173

# Phase 2 — Emails (optionnel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@email.com
# SMTP_PASS=app-password
